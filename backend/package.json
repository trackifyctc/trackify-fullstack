{
  "name": "trackify-backend",
  "version": "2.0.0",
  "description": "NestJS backend for the Trackify Warehouse Inventory System",
  "author": "Trackify Team",
  "private": true,
  "license": "MIT",
  "type": "commonjs",
  "main": "dist/main.js",

  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",

    "start": "node dist/main",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",

    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",

    "lint": "echo \"Linting skipped\"",

    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",

    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js --dataSource src/config/data-source.ts",
    "migration:generate": "npm run typeorm -- migration:generate",
    "migration:run": "npm run typeorm -- migration:run"
  },

  "dependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/swagger": "^11.3.0",
    "@nestjs/typeorm": "^11.0.1",

    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "rimraf": "^5.0.5",
    "typeorm": "^0.3.19",
    "uuid": "^9.0.1"
  },

  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.19",

    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@types/supertest": "^2.0.12",

    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",

    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",

    "jest": "^29.7.0",

    "nodemon": "^3.1.14",

    "prettier": "^3.1.1",

    "supertest": "^6.3.3",

    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  },

  "repository": {
    "type": "git",
    "url": "git+https://github.com/trackifyctc/trackify-backend.git"
  },

  "bugs": {
    "url": "https://github.com/trackifyctc/trackify-backend/issues"
  },

  "homepage": "https://github.com/trackifyctc/trackify-backend#readme"
}